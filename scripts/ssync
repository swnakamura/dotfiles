#!/bin/bash
# Safe rsync. shows you the outcome beforehand by executing the command with -nv flag. Adds `-h --info=progress2` in the final execution.

if [[ $1 == -V ]]; then
    # If the first option is -V , skip showing the file list
    shift
else
    ASKCOPY=1
fi

args=(-h --exclude-from="$HOME/.rsyncignore")

# cmux等にOSC 777通知を出す (確認プロンプトのタイミングで音を鳴らす用)
notify() {
    local msg="$1"
    local seq="\033]777;notify;ssync;${msg}\007"
    if [[ -n "$TMUX" ]]; then
        printf "\033Ptmux;\033${seq}\033\\"
    else
        printf "${seq}"
    fi
}

# sourceが末尾 / の場合、targetのbasenameがsourceのbasenameと一致していなければ警告
positional=()
for arg in "$@"; do
    [[ "$arg" != -* ]] && positional+=("$arg")
done
n=${#positional[@]}
if (( n >= 2 )); then
    target="${positional[$((n-1))]}"
    tgt_base=$(basename "$target")
    for ((i=0; i<n-1; i++)); do
        src="${positional[i]}"
        if [[ "$src" == */ ]]; then
            src_base=$(basename "$src")
            if [[ "$src_base" != "$tgt_base" ]]; then
                printf "\033[33m警告: source '%s' は末尾が / ですが target '%s' の basename が一致しません (期待: %s/)\033[0m\n" "$src" "$target" "$src_base" >&2
                notify "確認待ち: source の basename 不一致"
                read -n1 -p "続行しますか? (Y/OTHERS): " warn_answer
                echo ""
                if [[ "$warn_answer" != "Y" ]]; then
                    echo "Aborted"
                    exit 1
                fi
            fi
        else
            # 末尾スラッシュなし: target配下にsourceのbasenameと同名のディレクトリが新規作成される場合は警告
            # targetがリモート (host:path) の場合は存在確認できないのでスキップ
            if [[ "$target" != *:* ]]; then
                src_base=$(basename "$src")
                if [[ -d "$target" ]]; then
                    dest_path="${target%/}/$src_base"
                else
                    dest_path="$target"
                fi
                if [[ ! -e "$dest_path" ]]; then
                    new_dest_warnings+=("$dest_path")
                fi
            fi
        fi
    done
fi

# -V なし & -a あり の場合、--chmod でパーミッションを正規化するか確認
# (exFAT/SDカード由来の余計な実行ビットや、他ユーザが読めない権限を 644/755 に揃える用)
chmod_opt=""
if [[ -n "$ASKCOPY" ]]; then
    has_a=
    for arg in "$@"; do
        # --archive、または -a を含む短縮オプションの束 (例 -a, -av, -azP) を検出。長オプション(--xxx)は除外
        if [[ "$arg" == "--archive" ]] || [[ "$arg" == -[!-]* && "$arg" == *a* ]]; then
            has_a=1
            break
        fi
    done
    if [[ -n "$has_a" ]]; then
        notify "確認待ち: --chmod を付けますか?"
        read -n1 -p "-a 検出。--chmod=F644,D755 を付けて権限を正規化しますか? (y/N): " chmod_answer
        echo ""
        if [[ "$chmod_answer" == [yY] ]]; then
            chmod_opt="--chmod=F644,D755"
            args+=("$chmod_opt")
        fi
    fi
fi

if [[ -n "$ASKCOPY" ]]; then
    printf "\033[34m"
    rsync -vn "$@" "${args[@]}"
    printf "\033[0m"
fi

# -vn出力後に新規作成警告を表示 (ユーザーの確認直前に流れず確実に見えるように)
if (( ${#new_dest_warnings[@]} > 0 )); then
    for dest_path in "${new_dest_warnings[@]}"; do
        printf "\033[38;5;208m警告: '%s' は新しく作成されます\033[0m\n" "$dest_path" >&2
    done
fi

command="rsync --info=progress2 $@ ${chmod_opt:+$chmod_opt }-h --exclude-from=$HOME/.rsyncignore"
announce="Commencing \`${command}\`"

cols=$(tput cols 2>/dev/null)
if [[ $? != 0 ]]; then
    # tput failed somehow
    cols=80
else
    announce_len=${#announce}
    cols=$((cols<announce_len ? cols : announce_len))
fi

sep=$(for ((i=1; i<=cols; i++)); do printf "-"; done)

echo ""
echo $sep
echo $announce
echo $sep

if [[ -n "$ASKCOPY" ]]; then
    echo ""
    notify "確認待ち: 実行してよいですか?"
    read -n1 -p "ok? (y/N): " answer

    if [[ "$answer" != [yY] ]]; then
        echo ""
        echo "Aborted"
        exit 1
    fi
fi

echo ""
echo "Running..."
rsync --info=progress2 "$@" "${args[@]}"
echo "Done."
