# Font
font-family = JetBrains Mono
font-size = 14
# kitty had: bold=SemiBold, bold-italic=SemiBold; let Ghostty auto-detect weight variants
font-style = Light
font-style-bold = SemiBold
font-style-bold-italic = SemiBold Italic

# Cursor
cursor-style = block
cursor-style-blink = false

# Window
confirm-close-surface = true
# background-opacity = 0.93

# Scrollback (kitty had a custom nvim pager; Ghostty uses built-in scrollback)
scrollback-limit = 100000

theme = TokyoNight Night

# Font size
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+zero=reset_font_size

# Splits
# ctrl+shift+' → hsplit (new pane right), ctrl+shift+5 → vsplit (new pane below)
keybind = ctrl+shift+apostrophe=new_split:down
keybind = ctrl+shift+5=new_split:right
keybind = ctrl+shift+enter=toggle_split_zoom

# Close pane/tab
keybind = super+w=close_surface

# Tabs
keybind = super+t=new_tab

keybind = ctrl+shift+page_down=next_tab
keybind = ctrl+shift+page_up=previous_tab

# Tab by number
keybind = super+one=goto_tab:1
keybind = super+two=goto_tab:2
keybind = super+three=goto_tab:3
keybind = super+four=goto_tab:4
keybind = super+five=goto_tab:5
keybind = super+six=goto_tab:6
keybind = super+seven=goto_tab:7
keybind = super+eight=goto_tab:8
keybind = super+nine=goto_tab:9

# Split navigation
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+j=goto_split:down

macos-option-as-alt = true

# Notification
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 5s

# cwd inheritance
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true
